[Unit]
Description=IBC Wastewater Treatment Backend Service
After=network.target

[Service]
Type=simple
User=fourat
Group=fourat
WorkingDirectory=/home/fourat/IBC_Siedlungswasser_2/backend
Environment="PATH=/home/fourat/IBC_Siedlungswasser_2/backend/venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="HARDWARE_MODE=gpio"
Environment="HOST=0.0.0.0"
Environment="PORT=5000"
Environment="DEBUG=False"
ExecStart=/home/fourat/IBC_Siedlungswasser_2/backend/venv/bin/python /home/fourat/IBC_Siedlungswasser_2/backend/app.py
Restart=always
RestartSec=10
StandardOutput=append:/home/fourat/IBC_Siedlungswasser_2/backend/backend.log
StandardError=append:/home/fourat/IBC_Siedlungswasser_2/backend/backend.log

[Install]
WantedBy=multi-user.target
